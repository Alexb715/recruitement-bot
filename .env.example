# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Channel where completed interview embeds are posted
RESULTS_CHANNEL_ID=000000000000000000

# Role pinged when a new application is submitted
RECRUITER_ROLE_ID=000000000000000000

# Optional: channel where the persistent "Apply Here" button should live.
# When set, the bot auto-posts the button there on startup and reuses the
# same message across restarts. Leave blank to disable auto-posting (you can
# still use the /post-apply-message command manually).
APPLY_CHANNEL_ID=

# Optional: channel where the persistent FAQ message should live. When set, the
# bot auto-posts the FAQ embed there on startup and reuses the same message
# across restarts. Leave blank to disable auto-posting (you can still use the
# /post-faq command manually).
FAQ_CHANNEL_ID=

# Optional: channel where the persistent Requirements message should live. Same
# auto-post + reuse behavior as FAQ_CHANNEL_ID. Leave blank to use
# /post-requirements manually instead.
REQUIREMENTS_CHANNEL_ID=

# Optional: channel/role IDs rendered as clickable mentions inside the FAQ text.
# Leave any blank to fall back to plain-text wording for that reference.
FAQ_INTERVIEW_REQUEST_CHANNEL_ID=
FAQ_RULES_CHANNEL_ID=
FAQ_OPP_RECRUITMENT_CHANNEL_ID=
FAQ_SUPPORT_ROLE_ID=

# Optional: guild ID for instant slash-command sync during development.
# Leave blank for global sync (can take up to 1 hour to propagate).
DEV_GUILD_ID=

# Path to the SQLite database file (relative to project root)
DB_PATH=data/applications.db
